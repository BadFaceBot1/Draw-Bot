{
  "version": 2,
  "functions": {
    "api/index.py": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/webhook", "destination": "/api/index.py" },
    { "source": "/api/set_webhook", "destination": "/api/index.py" },
    { "source": "/api/verify_leagues", "destination": "/api/index.py" },
    { "source": "/api/run_daily", "destination": "/api/index.py" }
  ],
  "crons": [
    { 
      "path": "/api/run_daily", 
      "schedule": "5 0 * * *" 
    }
  ]
}
